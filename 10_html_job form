            <input type="text"><br><br>
             <label for="">Skills:</label>
            <textarea rows="5"cols="60"></textarea><br><br>
            </fieldset>
            <fieldset>
                <legend>Address detais:</legend>
            <label for="">City:</label>
            <input type="text"><br><br>
             <label for="">State:</label>
            <input type="text"><br><br>
             <label for="">Pin Code:</label>
            <input type="text"><br><br>
            <label for="">Country:</label>
            <input type="text">
      </fieldset>
      <br>
      <fieldset>
        <legend><b>photo & signature</b></legend>
        <label for="">Upload photo:</label>
        <input type="file"><br><br>
        <label for="">Upload Signature:</label>
        <input type="file">
      </fieldset>
      <br>
      <fieldset>
        <legend><b>Required Documents</b></legend>
        <label for="">Resume/cv:</label>
        <input type="file"><br><br>
        <label for="">Aadhaar card:</label>
        <input type="file"><br><br>
        <label for="">PAN card:</label>
        <input type="file"><br><br>
        <label for="">10th Marksheet:</label>
        <input type="file"><br><br>
         <label for="">12th Marksheet:</label>
        <input type="file"><br><br>
        <label for="">Graduation certificate:</label>
        <input type="file"><br><br>
        <label for="">Other Document:</label>
        <input type="file"muitiple>
      </fieldset>
      <br><br>
      <fieldset>
          <legend><b>Declaration</b></legend>
          <input type="checkbox">I hereby declare that all the information provided above 
          is true and correct to thre best of my knowledge
      </fieldset>
