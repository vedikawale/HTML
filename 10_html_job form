<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>job application</title>
</head>
<body>
    <center>
      <h2>Job Applicatio Form</h2>
      </center>
      <form>
        <fieldset>
            <legend><b>personal details</b></legend>
          <label for="">Student name:</label>
