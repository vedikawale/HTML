<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>job application</title>
</head>
<body>
    <center>
      <h2>Job Applicatio Form</h2>
      </center>
      <form>
        <fieldset>
            <legend><b>personal details</b></legend>
          <label for="">Student name:</label>
          <input type="text"><br><br>
          <label for="">Father name:</label>
          <input type="text"><br><br>
          <label for="">Mother name:</label>
          <input type="text"><br><br>
          <label for="">Email:</label>
          <input type="email"><br><br>
          <label for="">Date of Birth</label>
          <input type="date"><br><br>
          <label for="">Gender</label>
          <input type "radio" name="gender">male
           <input type "radio" name="gender">female 
           <br><br>
           <label for="">mobile number</label>
           <input type="tel"><br><br>
           <label for="">Marital status </label>
           <select>
            <option>select</option>
            <option>single</option>
            <option>married</option>
         </select>
        </fieldset>
        <br>
        <fieldset>
            <legend>Educational details</legend>
            <label for="">10th percentage</label>
            <input type="text"><br><br>
            <label for="">12th percentage</label>
            <input type="text"><br><br>
            <label for="">Graduation:</label>
            <input type="text"><br><br>
            <label for="">university</label>
            <input type="text"><br><br>
            <label for="">passing year</label>
            <input type="text"><br><br>
            <label for="">Additional Qualification</label>
            <input type="text"><br><br>
        </fieldset>
        <br>
        <legend>Experience details</legend>
        <label for="">Total Experience</label>
        <input type="range"><br><br>
        <label for="">Previous Company</label>
        <label for="">Skills:</label>
        <textarea rows="4" colos="30"></textarea>
        <br>
        <input type="submit" value="Submit">
        <input type="reset" value="Reset">
      </form>
</body>
</html>